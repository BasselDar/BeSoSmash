<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#0f172a">
<link rel="manifest" href="/manifest.json">
<title>
    <%= typeof title !=='undefined' ? title : 'BeSoSmash' %>
</title>

<!-- SEO Meta Tags -->
<meta name="description"
    content="BeSoSmash: The ultimate rage quit simulator and keyboard mashing test. Test your APM, mechanical keyboard switches, and discover your gamer personality in this chaotic stress relief game." />
<meta name="keywords"
    content="rage quit simulator, keyboard mashing test, stress relief game, aggressive typing test, smash keyboard online, APM checker, keyboard rollover test, mechanical keyboard tester, anti-ghosting test, ADHD clicking game, digital fidget toy, boredom cure, unhinged browser games, fast typing test, keyboard durability test, keyboard sound test, ASMR keyboard, CPS test, click speed test, unblocked games, keyboard stress test, mechanical switch tester, typing practice, gamer personality test" />

<!-- Open Graph / Link Sharing Meta Tags -->
<meta property="og:title" content="BeSoSmash - The Ultimate Keyboard Smashing Game" />
<meta property="og:description"
    content="Burn off steam with the world's most chaotic keyboard mashing simulator. Test your speed, accuracy, and sanity." />
<meta property="og:image" content="https://besosmash.com/assets/banner.png" />
<meta property="og:url" content="https://besosmash.com/" />
<meta property="og:type" content="website" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="BeSoSmash - Rage Quit Simulator" />
<meta name="twitter:description" content="The world's first competitive keyboard smashing game. Break your keyboard" />
<meta name="twitter:image" content="https://besosmash.com/assets/banner.png" />

<link rel="icon" type="image/png" href="/assets/icons/icon-64x64.png">
<link rel="apple-touch-icon" href="/assets/icons/icon-192x192.png">
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
<link
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;800&family=Outfit:wght@400;700;900&display=swap"
    rel="stylesheet">
<script>
    tailwind.config = {
        theme: {
            extend: {
                fontFamily: {
                    sans: ['Outfit', 'sans-serif'],
                    mono: ['"JetBrains Mono"', 'monospace'],
                },
                animation: {
                    'gradient-x': 'gradient-x 15s ease infinite',
                    'float': 'float 6s ease-in-out infinite',
                },
                keyframes: {
                    'gradient-x': {
                        '0%, 100%': { 'background-size': '200% 200%', 'background-position': 'left center' },
                        '50%': { 'background-size': '200% 200%', 'background-position': 'right center' },
                    },
                    'float': {
                        '0%, 100%': { transform: 'translateY(0)' },
                        '50%': { transform: 'translateY(-10px)' },
                    }
                }
            }
        }
    }
</script>
<style>
    .neon-glow {
        text-shadow: 0 0 10px currentColor, 0 0 20px currentColor, 0 0 30px currentColor;
    }

    .box-glow {
        box-shadow: 0 0 15px currentColor, inset 0 0 10px currentColor;
    }

    .glass-panel {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }
</style>
<script>
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js')
                .then(reg => console.log('Service Worker registered', reg))
                .catch(err => console.log('Service Worker registration failed', err));
        });
    }
</script>
<%- typeof extraHead !=='undefined' ? extraHead : '' %>